{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyPLTMiEDw868gi+ItxojE7J"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","execution_count":10,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"RMKvsXNFrWw3","executionInfo":{"status":"ok","timestamp":1777306633262,"user_tz":180,"elapsed":117009,"user":{"displayName":"Bianca Kim","userId":"11675434087238250833"}},"outputId":"007f9756-9a45-42d3-85a7-26c3b9879f47"},"outputs":[{"output_type":"stream","name":"stdout","text":["Cole os dados recebidos (pressione Enter + Ctrl+D ou deixe em branco e dê Enter para finalizar):\n","Followers: April 26th X: 495,121 LinkedIn: 1,143,448 IG: 126,980 TikTok: 9,983 Threads: 15,326 Você, Agora\n","\n","\n","✅ Sucesso! 5 linhas adicionadas à planilha 'MSFT_Followers'.\n"]}],"source":["import pandas as pd\n","import re\n","from google.colab import auth\n","from google.auth import default\n","import gspread\n","\n","# 1. Autenticação\n","auth.authenticate_user()\n","creds, _ = default()\n","gc = gspread.authorize(creds)\n","\n","# --- CONFIGURAÇÃO ---\n","NOME_DA_PLANILHA = \"MSFT_Followers\" # Altere para o nome exato do arquivo no Drive\n","# ---------------------\n","\n","def atualizar_seguidores():\n","    print(\"Cole os dados recebidos (pressione Enter + Ctrl+D ou deixe em branco e dê Enter para finalizar):\")\n","\n","    # Captura múltiplas linhas de input\n","    input_data = []\n","    while True:\n","        try:\n","            line = input()\n","            if not line: break\n","            input_data.append(line)\n","        except EOFError:\n","            break\n","\n","    texto_bruto = \"\\n\".join(input_data)\n","\n","    # 2. Extração da Data\n","    data_match = re.search(r\"(\\w+ \\d+º?|\\d{2}/\\d{2})\", texto_bruto)\n","    data_str = data_match.group(1) if data_match else \"Data não encontrada\"\n","\n","    # 3. Mapeamento de Redes e Padrões\n","    redes = {\n","        \"X\": r\"X:\\s*([\\d,.]+)\",\n","        \"LinkedIn\": r\"LinkedIn:\\s*([\\d,.]+)\",\n","        \"IG\": r\"IG:\\s*([\\d,.]+)\",\n","        \"TikTok\": r\"TikTok:\\s*([\\d,.]+)\",\n","        \"Threads\": r\"Threads:\\s*([\\d,.]+)\"\n","    }\n","\n","    novos_dados = []\n","\n","    for rede, padrao in redes.items():\n","        match = re.search(padrao, texto_bruto)\n","        if match:\n","            # Remove pontos e vírgulas para transformar em número inteiro\n","            valor = int(re.sub(r\"[.,]\", \"\", match.group(1)))\n","            novos_dados.append([data_str, rede, valor])\n","\n","    # 4. Gravação na Planilha\n","    try:\n","        sh = gc.open(NOME_DA_PLANILHA)\n","        wks = sh.get_worksheet(0) # Pega a primeira aba\n","\n","        for linha in novos_dados:\n","            wks.append_row(linha)\n","\n","        print(f\"\\n✅ Sucesso! {len(novos_dados)} linhas adicionadas à planilha '{NOME_DA_PLANILHA}'.\")\n","    except Exception as e:\n","        print(f\"\\n❌ Erro: Verifique se o nome da planilha está correto. Detalhes: {e}\")\n","\n","atualizar_seguidores()"]}]}